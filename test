using System;
using System.IO;
using System.Text;
using Microsoft.SqlServer.Dts.Runtime;

public void Main()
{
    try
    {
        string inputFile = Dts.Variables["User::InputFile"].Value.ToString();
        string outputFile = Dts.Variables["User::OutputFile"].Value.ToString();

        // Read file as UTF-8
        string content = File.ReadAllText(inputFile, Encoding.UTF8);

        // Write file as ANSI (Windows-1252)
        File.WriteAllText(outputFile, content, Encoding.GetEncoding(1252));

        Dts.TaskResult = (int)ScriptResults.Success;
    }
    catch (Exception ex)
    {
        Dts.Events.FireError(0, "Encoding Conversion", ex.Message, "", 0);
        Dts.TaskResult = (int)ScriptResults.Failure;
    }
}
