$folder = "C:\SSIS\Packages"   # folder containing dtsx files
$output = "C:\SSIS\ssis_inventory.csv"

$results = @()

Get-ChildItem $folder -Filter *.dtsx -Recurse | ForEach-Object {

    $file = $_.FullName
    Write-Host "Processing $file"

    [xml]$xml = Get-Content $file

    $ns = New-Object System.Xml.XmlNamespaceManager($xml.NameTable)
    $ns.AddNamespace("DTS","www.microsoft.com/SqlServer/Dts")

    $packageName = $_.BaseName

    # -----------------------------
    # Source DB Connection
    # -----------------------------
    $srcConnNode = $xml.SelectSingleNode("//connection/@connectionManagerRefId",$ns)
    $srcConn = $null

    if($srcConnNode){
        if($srcConnNode.Value -match "\[(.*?)\]"){
            $srcConn = $matches[1]
        }
    }

    # -----------------------------
    # Flat File Connection Manager
    # -----------------------------
    $flatConn = $xml.SelectSingleNode("//DTS:ConnectionManager[@DTS:CreationName='FLATFILE']", $ns)

    $filePath = ""
    $fileName = ""
    $delimiter = ""
    $textQualifier = ""

    if($flatConn){

        $connStr = $flatConn.SelectSingleNode(".//DTS:ConnectionString",$ns)

        if($connStr){
            $fullPath = $connStr.InnerText.Trim('"')
            $filePath = Split-Path $fullPath
            $fileName = Split-Path $fullPath -Leaf
        }

        $delimiterNode = $flatConn.SelectSingleNode(".//DTS:FlatFileColumn/@DTS:ColumnDelimiter",$ns)
        if($delimiterNode){
            $delimiter = $delimiterNode.Value
        }

        $qualNode = $flatConn.SelectSingleNode(".//DTS:ConnectionManager/@DTS:TextQualifier",$ns)
        if($qualNode){
            $textQualifier = $qualNode.Value
        }
    }

    # -----------------------------
    # Variables (SQL commands)
    # -----------------------------
    $variables = $xml.SelectNodes("//DTS:Variable",$ns)

    $sqlText = ""
    $variableName = ""

    foreach($var in $variables){

        $valueNode = $var.SelectSingleNode(".//DTS:VariableValue",$ns)

        if($valueNode){
            $val = $valueNode.InnerText

            if($val -match "EXEC\s+\[?dbo\]?\.\[?(\w+)\]?"){
                $sqlText = $matches[0]
                $variableName = $var.Attributes["DTS:ObjectName"].Value
                break
            }
        }
    }

    $results += [PSCustomObject]@{
        Package = $packageName
        SourceConnection = $srcConn
        SQLVariable = $variableName
        StoredProcedure = $sqlText
        FilePath = $filePath
        FileName = $fileName
        ColumnDelimiter = $delimiter
        TextQualifier = $textQualifier
    }

}

$results | Export-Csv $output -NoTypeInformation

Write-Host "Done. Output file: $output"
