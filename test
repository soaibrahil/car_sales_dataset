$folder = "C:\SSIS\Solution"

$results = @()

Get-ChildItem $folder -Filter *.dtsx -Recurse | ForEach-Object {

    $file = $_.FullName
    [xml]$pkg = Get-Content $file

    # Namespace handling
    $ns = New-Object System.Xml.XmlNamespaceManager($pkg.NameTable)
    $ns.AddNamespace("DTS","www.microsoft.com/SqlServer/Dts")

    # -----------------------------
    # Get Flat File Connection Info
    # -----------------------------
    $flatConn = $pkg.SelectNodes("//DTS:ConnectionManager[contains(@DTS:CreationName,'FLATFILE')]", $ns)

    foreach ($conn in $flatConn) {

        $connName = $conn.DTS:ObjectName
        $connString = $conn.DTS:ConnectionManager.DTS:Property |
            Where-Object { $_.DTS:Name -eq "ConnectionString" } |
            Select-Object -ExpandProperty '#text'

        $columnDelimiter = $conn.DTS:ConnectionManager.DTS:Property |
            Where-Object { $_.DTS:Name -eq "ColumnDelimiter" } |
            Select-Object -ExpandProperty '#text'

        $textQualifier = $conn.DTS:ConnectionManager.DTS:Property |
            Where-Object { $_.DTS:Name -eq "TextQualifier" } |
            Select-Object -ExpandProperty '#text'

        $filePath = [System.IO.Path]::GetDirectoryName($connString)
        $fileName = [System.IO.Path]::GetFileName($connString)

        # --------------------------------
        # Get OLE DB Source inside Dataflow
        # --------------------------------
        $oledbSources = $pkg.SelectNodes("//component[@componentClassID='{165A526D-D5DE-47FF-96A6-F8274C19826A}']")

        foreach ($src in $oledbSources) {

            $connMgr = $src.connections.connection |
                Where-Object { $_.name -eq "OleDbConnection" } |
                Select-Object -ExpandProperty connectionManagerID

            $sqlVar = $src.properties.property |
                Where-Object { $_.name -eq "SqlCommandVariable" } |
                Select-Object -ExpandProperty '#text'

            $results += [PSCustomObject]@{
                Package              = $_.Name
                OLEDBConnection      = $connMgr
                SQLVariable          = $sqlVar
                FlatFileConnection   = $connName
                FilePath             = $filePath
                FileName             = $fileName
                ColumnDelimiter      = $columnDelimiter
                TextQualifier        = $textQualifier
            }
        }
    }
}

$results | Export-Csv "ssis_metadata_output.csv" -NoTypeInformation
