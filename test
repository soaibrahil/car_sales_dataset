public void Main()
{
    try
    {
        // Define the output file path
        string filePath = @"C:\Output\MyFile.txt";

        // ANSI encoding (Windows-1252)
        Encoding ansiEncoding = Encoding.GetEncoding(1252);

        // Create the directory if it doesn't exist
        string directory = Path.GetDirectoryName(filePath);
        if (!Directory.Exists(directory))
        {
            Directory.CreateDirectory(directory);
        }

        // Write content using raw bytes to guarantee ANSI detection
        using (FileStream fs = new FileStream(filePath, FileMode.Create, FileAccess.Write))
        {
            // Your actual content lines
            string[] lines = new string[]
            {
                "Header1\tHeader2\tHeader3",
                "Value1\tValue2\tValue3",
                "Value4\tValue5\tValue6"
            };

            string content = string.Join(Environment.NewLine, lines);

            // Convert to ANSI bytes and write directly
            byte[] ansiBytes = ansiEncoding.GetBytes(content);
            fs.Write(ansiBytes, 0, ansiBytes.Length);
        }

        // -----------------------------------------------------------
        // WHY NOTEPAD STILL SHOWS "UTF-8":
        // -----------------------------------------------------------
        // If ALL your characters are plain ASCII (a-z, 0-9, etc.),
        // Notepad cannot distinguish ANSI from UTF-8 because ASCII
        // is identical in both encodings. It defaults to "UTF-8".
        //
        // Notepad will show "ANSI" only when the file contains bytes
        // in the 0x80-0xFF range that form valid Windows-1252 chars
        // but are INVALID as UTF-8 sequences.
        //
        // If your real data has special characters (é, ñ, ü, £, ©),
        // Notepad will correctly detect it as ANSI automatically.
        //
        // If your data is pure ASCII and you MUST see "ANSI" in 
        // Notepad, you can embed a non-visible marker character:
        // -----------------------------------------------------------

        // OPTIONAL: Force ANSI detection by writing a marker byte
        // Uncomment the block below ONLY if your content is pure ASCII
        // and you absolutely need Notepad to show "ANSI".
        //
        // This writes a soft-hyphen (0xAD) at the end of the file,
        // which is invisible in most contexts but forces ANSI detection.
        /*
        using (FileStream fs = new FileStream(filePath, FileMode.Create, FileAccess.Write))
        {
            string[] lines = new string[]
            {
                "Header1\tHeader2\tHeader3",
                "Value1\tValue2\tValue3"
            };

            string content = string.Join(Environment.NewLine, lines);
            byte[] ansiBytes = ansiEncoding.GetBytes(content);
            fs.Write(ansiBytes, 0, ansiBytes.Length);

            // Append soft-hyphen byte (0xAD) — invisible but forces ANSI
            fs.WriteByte(0xAD);
        }
        */

        Dts.Events.FireInformation(0, "Script Task",
            "ANSI file created successfully at: " + filePath, "", 0, ref fireAgain);

        Dts.TaskResult = (int)ScriptResults.Success;
    }
    catch (Exception ex)
    {
        Dts.Events.FireError(0, "Script Task",
            "Error creating file: " + ex.Message, "", 0);
        Dts.TaskResult = (int)ScriptResults.Failure;
    }
}

bool fireAgain = false;
