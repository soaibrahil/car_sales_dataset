// using System.IO;
// using System.Text;

public void Main()
{
    try
    {
        // Define the output file path
        // You can also read this from an SSIS variable:
        // string filePath = Dts.Variables["User::FilePath"].Value.ToString();
        string filePath = @"C:\Output\MyFile.txt";

        // Define content to write
        string content = "This is a sample ANSI encoded text file created from SSIS.";

        // ANSI encoding (Windows-1252, the most common ANSI code page)
        Encoding ansiEncoding = Encoding.GetEncoding(1252);

        // Create the directory if it doesn't exist
        string directory = Path.GetDirectoryName(filePath);
        if (!Directory.Exists(directory))
        {
            Directory.CreateDirectory(directory);
        }

        // Option 1: Write a simple string to the file
        File.WriteAllText(filePath, content, ansiEncoding);

        // Option 2: Write multiple lines using StreamWriter
        /*
        using (StreamWriter writer = new StreamWriter(filePath, false, ansiEncoding))
        {
            writer.WriteLine("Header1\tHeader2\tHeader3");
            writer.WriteLine("Value1\tValue2\tValue3");
            writer.WriteLine("Value4\tValue5\tValue6");
        }
        */

        // Option 3: Create an empty ANSI file (no content)
        /*
        using (StreamWriter writer = new StreamWriter(filePath, false, ansiEncoding))
        {
            // File is created empty with ANSI encoding
        }
        */

        // Log success
        Dts.Events.FireInformation(0, "Script Task",
            "ANSI file created successfully at: " + filePath, "", 0, ref fireAgain);

        Dts.TaskResult = (int)ScriptResults.Success;
    }
    catch (Exception ex)
    {
        Dts.Events.FireError(0, "Script Task",
            "Error creating file: " + ex.Message, "", 0);
        Dts.TaskResult = (int)ScriptResults.Failure;
    }
}

// Declare this at the class level
bool fireAgain = false;
