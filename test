$folder = "C:\SSIS\SolutionFolder"
$output = "C:\SSIS\ssis_lineage_report.csv"

$results = @()

$files = Get-ChildItem $folder -Filter *.dtsx -Recurse

foreach ($file in $files) {

    [xml]$xml = Get-Content $file.FullName

    $ns = New-Object System.Xml.XmlNamespaceManager($xml.NameTable)
    $ns.AddNamespace("DTS","www.microsoft.com/SqlServer/Dts")

    $packageName = $file.Name

    # --------------------------
    # Get Stored Procedure
    # --------------------------

    $sp = ""
    $varNodes = $xml.SelectNodes("//DTS:Variable/DTS:VariableValue",$ns)

    foreach ($node in $varNodes) {

        if ($node.'#text' -match "EXEC\s+\[?dbo\]?\.\[?([a-zA-Z0-9_]+)\]?") {
            $sp = $matches[1]
            break
        }
    }

    # --------------------------
    # Get Source DB Connection
    # --------------------------

    $srcConn = ""

    $connNode = $xml.SelectSingleNode("//connections/connection/@connectionManagerRefId",$ns)

    if($connNode){
        if ($connNode.Value -match "\[(.*?)\]"){
            $srcConn = $matches[1]
        }
    }

    # --------------------------
    # Flat File Connection
    # --------------------------

    $filePath = ""
    $fileName = ""
    $delimiter = ""
    $textQualifier = ""

    $flatConn = $xml.SelectSingleNode("//DTS:ConnectionManager[@DTS:CreationName='FLATFILE']", $ns)

    if($flatConn){

        $connStr = $flatConn.SelectSingleNode(".//DTS:ObjectData//DTS:ConnectionManager/@DTS:ConnectionString",$ns)

        if($connStr){
            $full = $connStr.Value.Trim('"')

            $filePath = Split-Path $full
            $fileName = Split-Path $full -Leaf
        }

        $delNode = $flatConn.SelectSingleNode(".//DTS:FlatFileColumn/@DTS:ColumnDelimiter",$ns)

        if($delNode){
            $delimiter = $delNode.Value
        }

        $qualNode = $flatConn.SelectSingleNode(".//DTS:ObjectData//DTS:ConnectionManager/@DTS:TextQualifier",$ns)

        if($qualNode){
            $textQualifier = $qualNode.Value
        }
    }

    # Decode SSIS delimiter encoding
    if($delimiter -eq "_x007C_"){ $delimiter = "|" }
    if($delimiter -eq "_x0009_"){ $delimiter = "TAB" }

    # --------------------------
    # Add result row
    # --------------------------

    $results += [PSCustomObject]@{
        PackageName = $packageName
        SourceDBConnection = $srcConn
        StoredProcedure = $sp
        FilePath = $filePath
        FileName = $fileName
        ColumnDelimiter = $delimiter
        TextQualifier = $textQualifier
    }

}

$results | Export-Csv $output -NoTypeInformation

Write-Host "Report generated: $output"
